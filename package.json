{
  "name": "icontopia",
  "version": "0.1.0",
  "description": "Icontopia is a Figma plugin for browsing, importing, and version-syncing icons from open source icon libraries.",
  "main": "dist/code.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:ui && npm run build:plugin -- --minify",
    "build:plugin": "esbuild src/code.ts --bundle --target=es6 --outfile=dist/code.js",
    "build:ui": "vite build --minify esbuild --emptyOutDir=false",
    "build:watch": "concurrently -n widget,iframe \"npm run build:plugin -- --watch\" \"npm run build:ui -- --watch\"",
    "dev": "concurrently --kill-others-on-fail -n tsc,build,vite 'npm:tsc:watch' 'npm:build:watch' 'vite'",
    "test": "npm run tsc && npm run build",
    "tsc": "tsc --noEmit",
    "tsc:watch": "npm run tsc -- --watch --preserveWatchOutput",
    "version:bump:patch": "npm version patch --no-git-tag-version",
    "version:bump:minor": "npm version minor --no-git-tag-version",
    "version:bump:major": "npm version major --no-git-tag-version"
  },
  "author": "Atropical AS",
  "license": "GPL-3.0-only",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.130.0",
    "@types/node": "^26.0.1",
    "@types/react": "^18.2.17",
    "@types/react-dom": "^18.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "figma-kit": "^1.0.0-beta.23",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-generate-file": "^0.3.1",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
